# ── Sentry (monitoring erreurs) ─────────────────────────────
# Créer un projet sur https://sentry.io
# Copier le DSN depuis Project → Settings → Client Keys (DSN)
NEXT_PUBLIC_SENTRY_DSN=https://xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx@oxxxxxxx.ingest.sentry.io/xxxxxxx

# Upload des source maps au build (sinon les stack traces Sentry pointent vers du code
# minifié illisible — audit sécurité 2026-07-20). Sans ces 3 valeurs, le build fonctionne
# quand même, l'upload est juste sauté silencieusement.
#   SENTRY_ORG    : sentry.io → coin en haut à gauche, le slug dans l'URL (sentry.io/organizations/<org>/)
#   SENTRY_PROJECT: nom du projet Next.js dans Sentry (slug, pas le nom affiché)
#   SENTRY_AUTH_TOKEN : sentry.io → Settings → Auth Tokens → New Token, scope "project:releases"
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# ── Flask API ────────────────────────────────────────────────
# URL de l'API Flask (défaut: 127.0.0.1:18000 via next.config.ts rewrites)
# Laisser vide si Flask tourne en local sur le même serveur
NEXT_PUBLIC_API_URL=

# ── Environnement ────────────────────────────────────────────
NODE_ENV=production
