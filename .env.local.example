# ── Sentry (monitoring erreurs) ─────────────────────────────
# Créer un projet sur https://sentry.io
# Copier le DSN depuis Project → Settings → Client Keys (DSN)
NEXT_PUBLIC_SENTRY_DSN=https://xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx@oxxxxxxx.ingest.sentry.io/xxxxxxx

# ── Flask API ────────────────────────────────────────────────
# URL de l'API Flask (défaut: 127.0.0.1:18000 via next.config.ts rewrites)
# Laisser vide si Flask tourne en local sur le même serveur
NEXT_PUBLIC_API_URL=

# ── Environnement ────────────────────────────────────────────
NODE_ENV=production
